{
  "name": "translator-widget",
  "version": "1.0.0",
  "description": "Small always-on-top translator widget toggled with a global shortcut",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "restart": "launchctl kickstart -k gui/$(id -u)/com.quipo.translator",
    "autostart": "node scripts/autostart.js install",
    "autostart:remove": "node scripts/autostart.js uninstall"
  },
  "devDependencies": {
    "electron": "^33.0.0"
  },
  "allowScripts": {
    "electron@33.4.11": true
  }
}
